# ============================================
# VARIABLES D'ENVIRONNEMENT ChantierPro
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# ---- SUPABASE (gratuit) ----
# Crée ton projet sur https://supabase.com
# Settings > API > Project URL + anon public key
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key (UNIQUEMENT côté serveur, dans api/*)
SUPABASE_SERVICE_KEY=YOUR-SERVICE-KEY

# ---- MISTRAL AI (très peu cher) ----
# Crée ton compte sur https://console.mistral.ai
# API Keys > Create new key
MISTRAL_API_KEY=YOUR-MISTRAL-KEY

# ---- STRIPE ----
# Compte sur https://dashboard.stripe.com
# Developers > API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXX

# Price IDs (Products > ton produit > price_id)
VITE_STRIPE_PRICE_STARTER=price_XXXXX
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_XXXXX
VITE_STRIPE_PRICE_PRO=price_XXXXX
VITE_STRIPE_PRICE_PRO_ANNUAL=price_XXXXX
VITE_STRIPE_PRICE_BUSINESS=price_XXXXX
VITE_STRIPE_PRICE_BUSINESS_ANNUAL=price_XXXXX

# Les variables server-side (STRIPE_SECRET_KEY, etc.) doivent aussi être
# configurées dans Vercel : Settings > Environment Variables
